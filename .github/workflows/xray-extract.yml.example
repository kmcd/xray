# xray scheduled extraction — copy this file to .github/workflows/xray-extract.yml
# in the customer repo. Setup guide: docs/scheduled-extraction.md
name: xray scheduled extraction

on:
  workflow_dispatch: {}   # manual trigger always available
  schedule:
    # 02:00 UTC on the 1st of January, April, July, and October.
    # Edit to taste — standard five-field cron syntax.
    # Disable without touching this file: set XRAY_ENABLED=false (see below).
    - cron: '0 2 1 */3 *'

permissions:
  contents: read   # gh release download reads public release assets

# To pause the schedule without editing this file:
#   repo Settings → Secrets and variables → Actions → Variables → New repository variable
#   Name: XRAY_ENABLED   Value: false
# To re-enable, delete the variable or set it to any value other than 'false'.
jobs:
  extract:
    if: vars.XRAY_ENABLED != 'false'
    runs-on: ubuntu-latest
    # 12-hour cap covers a full-window extraction against large orgs.
    # Reduce to 60 if your org is small and you want faster failure feedback.
    timeout-minutes: 720

    steps:
      - name: install xray
        env:
          GH_TOKEN: ${{ github.token }}
        run: |
          # Pin to a specific release with the XRAY_VERSION repository variable
          # (e.g. "v0.4.8"). Omit the variable to always pull the latest release.
          # repo Settings → Secrets and variables → Actions → Variables → XRAY_VERSION
          VERSION="${{ vars.XRAY_VERSION || 'latest' }}"
          gh release download "$VERSION" \
            --repo kmcd/xray \
            --pattern 'xray_*_linux_amd64.tar.gz' \
            --pattern 'checksums.txt'
          sha256sum --check --ignore-missing checksums.txt
          tar -xzf xray_*_linux_amd64.tar.gz
          chmod +x ./xray
          ./xray version   # records binary version and build date in the run log

      - name: prepare config
        env:
          XRAY_GH_TOKEN: ${{ secrets.XRAY_GH_TOKEN }}
        run: |
          TODAY=$(date -u +%Y-%m-%d)
          # Edit the teams block to list your repos (owner/repo slugs).
          # The window starts at 2021-01-01 — covering the pre-AI baseline
          # through today. Narrow by changing the start date.
          # Full config reference: docs/spec.md → Configuration
          cat > config.toml << EOF
          window = "2021-01-01..${TODAY}"

          [teams]
          # Team name is arbitrary; values are owner/repo slugs.
          engineering = [
            "your-org/repo-a",
            "your-org/repo-b",
          ]

          [connectors.github]
          token = "${XRAY_GH_TOKEN}"
          EOF

      - name: run extraction
        id: extract
        run: |
          # Name the artifact by year and quarter so re-runs don't overwrite.
          MONTH=$(date -u +%-m)
          QUARTER=$(( (MONTH - 1) / 3 + 1 ))
          ARTIFACT="xray-$(date -u +%Y)-Q${QUARTER}.tar.gz"
          # --output log: one structured line per phase to stdout instead of the live TUI.
          # Exit code 2 = partial success: artifact produced, connector errors in manifest.
          # Treat code 2 as success here; the upload step should still run.
          ./xray run config.toml --out "${ARTIFACT}" --output log || {
            EC=$?; [ "$EC" -eq 2 ] || exit "$EC"
          }
          echo "artifact=${ARTIFACT}" >> "$GITHUB_OUTPUT"

      # ── Handover option A: upload to a consultant-managed S3 bucket ──────────────
      # The consultant provides the bucket name and a write-only IAM key pair.
      # Secrets: CONSULTANT_BUCKET_KEY_ID, CONSULTANT_BUCKET_KEY_SECRET
      # Variables: CONSULTANT_BUCKET (e.g. "acme-xray-drop"), CONSULTANT_BUCKET_REGION
      # Remove this step (and its secrets) if you prefer option B below.
      - name: upload to S3
        env:
          AWS_ACCESS_KEY_ID: ${{ secrets.CONSULTANT_BUCKET_KEY_ID }}
          AWS_SECRET_ACCESS_KEY: ${{ secrets.CONSULTANT_BUCKET_KEY_SECRET }}
          AWS_DEFAULT_REGION: ${{ vars.CONSULTANT_BUCKET_REGION || 'us-east-1' }}
        run: |
          aws s3 cp "${{ steps.extract.outputs.artifact }}" \
            "s3://${{ vars.CONSULTANT_BUCKET }}/${{ steps.extract.outputs.artifact }}"

      # ── Handover option B: GitHub Actions artifact ────────────────────────────────
      # The consultant downloads from the workflow run via the repo's Actions UI.
      # Remove the S3 step above and uncomment this block to use option B instead.
      #
      # - name: upload artifact
      #   uses: actions/upload-artifact@v4
      #   with:
      #     name: ${{ steps.extract.outputs.artifact }}
      #     path: ${{ steps.extract.outputs.artifact }}
      #     retention-days: 90   # Actions artifacts expire; download before this date
